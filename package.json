{
  "name": "proof-play",
  "version": "0.1.0",
  "private": true,
  "description": "Verifiable same-match prediction pools powered by TxLINE and Solana.",
  "engines": {
    "node": ">=22.13.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "scripts/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@proof-play/web",
    "build": "npm run build --workspace=@proof-play/web",
    "start": "npm run start --workspace=@proof-play/web",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present && tsc -p tsconfig.tooling.json",
    "test": "npm run workspace:check && npm run test:unit",
    "test:unit": "vitest run",
    "test:rendered": "npm run test:rendered --workspace=@proof-play/web",
    "security:client-bundle": "node tooling/check-client-secrets.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "workspace:check": "node tooling/check-workspace-graph.mjs",
    "txline:address": "node --import tsx packages/txline/src/cli.ts address",
    "txline:diagnose": "node --import tsx packages/txline/src/cli.ts diagnose",
    "txline:activate": "node --import tsx packages/txline/src/cli.ts activate",
    "txline:recover": "node --import tsx packages/txline/src/cli.ts recover",
    "txline:renew": "node --import tsx packages/txline/src/cli.ts renew",
    "txline:verify": "node --import tsx packages/txline/src/cli.ts verify",
    "anchor:build": "anchor build",
    "anchor:test": "cargo test --workspace",
    "program:verify": "node --import tsx tooling/verify-pool-lifecycle-devnet.ts",
    "program:verify-proof": "node --import tsx tooling/verify-proof-settlement-devnet.ts",
    "demo:fund": "node --import tsx tooling/fund-demo-wallet-devnet.ts",
    "check": "npm run format:check && npm run workspace:check && npm run lint && npm run typecheck && npm run test:unit && npm run build && npm run security:client-bundle && npm run test:rendered && npm run anchor:test"
  },
  "devDependencies": {
    "@solana/spl-token": "0.4.15",
    "@types/node": "22.19.19",
    "prettier": "3.9.5",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  },
  "overrides": {
    "postcss": "8.5.19",
    "vite": "8.1.5"
  }
}
