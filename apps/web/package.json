{
  "name": "@proof-play/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test:rendered": "node --test tests/rendered-html.test.mjs"
  },
  "dependencies": {
    "@proof-play/condition-engine": "*",
    "@proof-play/domain": "*",
    "@proof-play/receipt": "*",
    "@proof-play/replay": "*",
    "@proof-play/txline": "*",
    "@solana/web3.js": "^1.98.4",
    "buffer": "^6.0.3",
    "next": "16.2.10",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.45.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "vinext": "0.0.50",
    "vite": "8.1.5",
    "wrangler": "4.112.0"
  }
}
